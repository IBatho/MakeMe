# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://makeme:makeme@localhost:5432/makeme
DATABASE_SYNC_URL=postgresql+psycopg2://makeme:makeme@localhost:5432/makeme

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME

ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGE_ME

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list; for Flutter dev use the local emulator address
CORS_ORIGINS=["http://localhost:3000","http://10.0.2.2:8000"]

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Debug ─────────────────────────────────────────────────────────────────────
DEBUG=false
