# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://makeme:makeme@localhost:5432/makeme
DATABASE_SYNC_URL=postgresql+psycopg2://makeme:makeme@localhost:5432/makeme

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME

ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGE_ME

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list; for Flutter dev use the local emulator address
CORS_ORIGINS=["http://localhost:3000","http://10.0.2.2:8000"]

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Integrations — Notion ─────────────────────────────────────────────────────
# Create at https://www.notion.so/my-integrations → OAuth integration
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# ── Integrations — Google Calendar ────────────────────────────────────────────
# Create at https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Integrations — Microsoft 365 ──────────────────────────────────────────────
# Register app at https://portal.azure.com → App registrations
# Required API permissions: Calendars.ReadWrite, offline_access
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ── OAuth redirect URLs ────────────────────────────────────────────────────────
# Backend URL that OAuth providers redirect back to (must be registered in each provider's dashboard)
OAUTH_REDIRECT_BASE_URL=http://localhost:8000

# Mobile app deep-link scheme
MOBILE_DEEP_LINK_SCHEME=makeme

# ── Anthropic (LLM advisor — optional) ────────────────────────────────────────
# Leave blank to disable LLM fallback; rule engine + bandit still run.
# Generate at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ── Debug ─────────────────────────────────────────────────────────────────────
DEBUG=false
